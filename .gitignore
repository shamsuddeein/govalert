# GovAlert — .gitignore

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# Virtual Environment
.venv/
venv/
env/

# Django
*.log
local_settings.py
staticfiles/
media/
htmlcov/
.coverage
coverage.xml

# Environment Variables — NEVER commit secrets
.env
!.env.example

# Database
*.sqlite3
*.db
*.db-shm
*.db-wal

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Docker
*.override.yml

# Node (if web dashboard is added later)
node_modules/

# Playwright
playwright/.auth/
test-results/
playwright-report/
