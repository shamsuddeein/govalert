# ─── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.development

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://govalert:password@localhost:5432/govalert_db

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Telegram Bot ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret-token
TELEGRAM_WEBHOOK_URL=https://yourdomain.com/telegram/webhook/

# ─── Admin Telegram IDs ────────────────────────────────────────────────────────
SUPER_ADMIN_TELEGRAM_IDS=123456789,987654321

# ─── Google AI (Gemini) ────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ─── AWS S3 (optional for dev, required for prod) ──────────────────────────────
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_STORAGE_BUCKET_NAME=govalert-media
AWS_S3_REGION_NAME=us-east-1

# ─── Email (optional) ──────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# ─── Security ──────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000
