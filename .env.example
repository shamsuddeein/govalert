# ─── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.development
DATABASE_URL=postgresql://govalert:change-me@localhost:5432/govalert
REDIS_URL=redis://localhost:6379/0

# ─── Telegram Bot ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret-token
TELEGRAM_WEBHOOK_URL=https://yourdomain.com/telegram/webhook/

# ─── Telegram Channels (Phase 1 Storage) ───────────────────────────────────────
# Create these channels in Telegram, add the bot as admin, then paste the IDs here.
# Get channel ID by forwarding a message to @userinfobot
TELEGRAM_EVENTS_CHANNEL_ID=-1001234567890    # govalert-events (private)
TELEGRAM_PUBLIC_CHANNEL_ID=-1009876543210    # govalert-public (public)
TELEGRAM_BACKUP_CHANNEL_ID=-1001122334455    # govalert-backup (private)

# ─── Admin Telegram IDs ────────────────────────────────────────────────────────
SUPER_ADMIN_TELEGRAM_IDS=123456789

# ─── Google AI (Gemini — free tier) ────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ─── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-5.6

# ─── Security ──────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─── Phase 2 (uncomment when adding PostgreSQL + Redis) ────────────────────────
# DB_NAME=govalert_db
# DB_USER=govalert
# DB_PASSWORD=your-password
# DB_HOST=localhost
# DB_PORT=5432
# AWS_STORAGE_BUCKET_NAME=govalert-media

# ─── Storage Backend Abstraction ──────────────────────────────────────────────
STORAGE_BACKEND=core.storage.DjangoORMStorageBackend
